# Production settings
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# PostgreSQL production database.
# Format:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=postgresql://autoparts_user:change-me@db-host:5432/autoparts

# Docker Compose local production-style database defaults.
POSTGRES_DB=autoparts
POSTGRES_USER=autoparts
POSTGRES_PASSWORD=change-me

# Cloudflare R2 media storage. Static files still use WhiteNoise.
USE_R2_STORAGE=True
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=your-r2-bucket
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_REGION_NAME=auto
R2_ENDPOINT_URL=
R2_LOCATION=media
# Optional, recommended for public images: images.your-domain.com
R2_CUSTOM_DOMAIN=
R2_QUERYSTRING_AUTH=False

# Container startup toggles.
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1
